{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/pre_tool_use.py",
            "commandWindows": "py -3 .codex\\hooks\\pre_tool_use.py",
            "timeout": 30,
            "statusMessage": "Checking Codex tool use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/stop_verify.py",
            "commandWindows": "py -3 .codex\\hooks\\stop_verify.py",
            "timeout": 300,
            "statusMessage": "Running project verification"
          }
        ]
      }
    ]
  }
}
